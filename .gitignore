# --- large data: rosbags + all runtime result artifacts (regenerated by the run scripts) ---
bags/
output/

# --- third-party ROS sources (reconstruct with: vcs import src < hmr_localisation.repos) ---
src/

# --- colcon build artifacts (build/, install/, log/ and any *_humble / *_glim variants
#     left over from the alternative-localizer experiments on the `experiments` branch) ---
build*/
install*/
log*/

# --- editor / python caches ---
.vscode/
__pycache__/
*.pyc

# --- machine-specific env (DISPLAY etc.) ---
.env

# --- Dear ImGui window-layout state (left over from the Iridescence/GLIM viewer) ---
imgui.ini

# --- downsampled .pcd maps generated from gt_map.ply (regenerate with
#     scripts/downsample_map_pcl.cpp). The source .ply is kept, and the 0.5 m
#     gt_map_us050.pcd default map (used by gt_ouster_ndt_realtime.yaml) is
#     committed; the rest of the sweep stays out of the repo. ---
gt_map/*.pcd
!gt_map/gt_map_us050.pcd
