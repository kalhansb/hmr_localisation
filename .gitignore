# --- large data: rosbags (recorded sensor data + results bags) ---
bags/
output/acc_bag/
output/*.mcap
output/*.npz

# --- dsbench: keep the harness scripts + result plots/summaries, drop the bulky
#     per-run artifacts (CSVs/logs), generated per-run configs, and compiled binary ---
output/dsbench/runs/
output/dsbench/cfg/
output/dsbench/bin/
output/dsbench/*.log

# --- third-party ROS sources (reconstruct with: vcs import src < hmr_localisation.repos) ---
src/

# --- colcon build artifacts ---
build/
install/
log/
build_humble/
install_humble/
log_humble/

# --- editor / python caches ---
.vscode/
__pycache__/
*.pyc

# --- machine-specific env (DISPLAY etc.) ---
.env

# --- Dear ImGui window-layout state ---
imgui.ini

# --- derived ICP map (regenerate: scripts/ply_to_pcd.py) ---
gt_map/*.pcd
