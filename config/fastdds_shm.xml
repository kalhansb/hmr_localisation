<?xml version="1.0" encoding="UTF-8" ?>
<!-- Shared-memory FastDDS transport for the localization pipeline. The Ouster
     clouds are multi-MB; over the default UDPv4 loopback they fragment and
     throttle to ~0.1 Hz (the localizer then sees ~8 s gaps between scans).
     Routing intra-host traffic over SHM (with a large segment) delivers them at
     the full 7.6 Hz. UDP is kept as a second transport for discovery/fallback.
     Enable with:  export FASTRTPS_DEFAULT_PROFILES_FILE=/ws/config/fastdds_shm.xml -->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>shm_transport</transport_id>
        <type>SHM</type>
        <segment_size>268435456</segment_size>   <!-- 256 MB pool for big clouds in flight -->
      </transport_descriptor>
      <transport_descriptor>
        <transport_id>udp_transport</transport_id>
        <type>UDPv4</type>
      </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="shm_first" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>shm_transport</transport_id>
          <transport_id>udp_transport</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
