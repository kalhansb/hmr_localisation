<?xml version="1.0" encoding="UTF-8" ?>
<!-- Force UDPv4-only transport (disable shared memory).
     Humble's Fast DDS (2.6) and Jazzy's (2.14) have incompatible SHM segment
     formats: cross-distro discovery succeeds over UDP multicast, but data sent
     over SHM is never received. Disabling the builtin transports and using a
     plain UDPv4 descriptor makes both ends exchange data over loopback UDP.
     Apply on BOTH the Jazzy container and the host Humble nodes via
     FASTRTPS_DEFAULT_PROFILES_FILE. -->
<dds>
  <profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>udp_transport</transport_id>
        <type>UDPv4</type>
        <!-- Large socket buffers for multi-MB Ouster PointCloud2 over UDP.
             Only effective up to the kernel cap (net.core.rmem_max /
             wmem_max). Default Ubuntu cap is ~208KB, far below a 2-4 MB
             cloud; raise it on the host AND inside the container, e.g.:
               sudo sysctl -w net.core.rmem_max=67108864
               sudo sysctl -w net.core.wmem_max=67108864 -->
        <sendBufferSize>16777216</sendBufferSize>
        <receiveBufferSize>16777216</receiveBufferSize>
      </transport_descriptor>
    </transport_descriptors>
    <participant profile_name="udp_only_participant" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>udp_transport</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
